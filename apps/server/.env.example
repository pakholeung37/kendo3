# Local development defaults
PORT=1200
LISTEN_INADDR_ANY=0
DATABASE_PATH=./data/kendo3.sqlite
POLL_SCAN_INTERVAL_MS=30000
RSS_FETCH_TIMEOUT_MS=15000

# Keep local setup self-contained
CACHE_TYPE=memory
NO_LOGFILES=true

# Optional browser automation settings
# CHROMIUM_EXECUTABLE_PATH=/path/to/chrome
# PUPPETEER_WS_ENDPOINT=ws://localhost:3000
