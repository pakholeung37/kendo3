{
    "name": "@kendo3/server",
    "version": "1.0.0",
    "private": true,
    "description": "Make RSS Great Again!",
    "keywords": [
        "RSS"
    ],
    "license": "MIT",
    "author": "DIYgod",
    "type": "module",
    "scripts": {
        "build": "tsdown",
        "dev": "NODE_ENV=dev bun --watch src/index.ts",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "lint": "biome lint .",
        "start": "NODE_ENV=production bun dist/index.mjs",
        "test": "bun run vitest:coverage",
        "typecheck": "tsc --noEmit",
        "vitest": "NODE_ENV=test vitest",
        "vitest:coverage": "NODE_ENV=test vitest --coverage.enabled",
        "vitest:watch": "NODE_ENV=test vitest --watch"
    },
    "dependencies": {
        "@hono/node-server": "1.19.14",
        "@hono/zod-openapi": "1.2.4",
        "dayjs": "1.11.20",
        "drizzle-orm": "0.44.5",
        "dotenv": "17.4.2",
        "hono": "4.12.12",
        "html-to-text": "9.0.5",
        "rss-parser": "3.13.0",
        "uuid": "13.0.0",
        "winston": "3.19.0",
        "zod": "4.3.6"
    },
    "devDependencies": {},
    "engines": {
        "bun": ">=1.3.9"
    }
}
