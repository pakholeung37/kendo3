{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "ESNext",
        "strict": true,
        "tsBuildInfoFile": "./tsconfig.tsbuildinfo",
        "jsx": "react-jsx",
        "jsxImportSource": "hono/jsx",
        "paths": {
            "@/*": ["./lib/*"]
        },
        "outDir": "./dist",
        "noEmit": true,
        "incremental": true,
        "resolveJsonModule": true,
        "isolatedModules": true
    },
    "include": ["./lib/**/*"],
    "exclude": ["node_modules", "dist", "coverage", "./lib/**/*.test.*", "./lib/**/*.spec.*", "./lib/routes"]
}
