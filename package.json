{
    "name": "kendo3",
    "private": true,
    "packageManager": "bun@1.3.9",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "cd apps/server && bun run dev",
        "dev:cache": "cd apps/server && bun run dev:cache",
        "build": "cd apps/server && bun run build",
        "start": "cd apps/server && bun run start",
        "lint": "cd apps/server && bun run lint",
        "format": "cd apps/server && bun run format",
        "format:check": "cd apps/server && bun run format:check",
        "test": "cd apps/server && bun run test",
        "smoke:bun": "bash scripts/smoke-server.sh",
        "docker:test": "bash scripts/docker/test-docker.sh"
    }
}
