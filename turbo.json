{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "assets/build/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "format": {
            "cache": false
        },
        "format:check": {
            "cache": false
        },
        "lint": {
            "cache": false
        },
        "typecheck": {
            "cache": false
        },
        "test": {
            "cache": false
        }
    }
}
